// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReservationType {
  ROOM
  POOL
  BOTH
}

enum MaintenanceType {
  DAILY
  MONTHLY
  DRAIN
}

enum PoolSlotLabel {
  MORNING
  AFTERNOON
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskFrequency {
  DAILY
  MONTHLY
  ONCE
}

enum InventoryType {
  SHOP
  MAINTENANCE
}

enum MovementType {
  IN // restock
  OUT // sold or used
}

//////////////////////
// USER
//////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  reservations Reservation[]

  assignedTasks      MaintenanceTask[]   @relation("TaskAssignedTo")
  createdTasks       MaintenanceTask[]   @relation("TaskCreatedBy")
  inventoryMovements InventoryMovement[]
}

//////////////////////
// ROOM
//////////////////////

model Room {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Decimal
  capacity    Int
  isActive    Boolean @default(true)

  reservations Reservation[]
}

//////////////////////
// POOL SLOT
//////////////////////

model PoolSlot {
  id        String        @id @default(uuid())
  label     PoolSlotLabel @unique
  startTime String
  endTime   String
  capacity  Int
  price     Decimal

  reservationSlots ReservationPoolSlot[]
}

model PoolSlotDisabled {
  id        String        @id @default(uuid())
  label     PoolSlotLabel
  date      DateTime
  reason    String?
  createdAt DateTime      @default(now())

  @@unique([label, date])
}

//////////////////////
// RESERVATION
//////////////////////

model Reservation {
  id               String            @id @default(uuid())
  customerName     String
  customerPhone    String
  customerLocation String?
  customerEmail    String?
  type             ReservationType
  status           ReservationStatus @default(PENDING)
  checkIn          DateTime? // add this
  checkOut         DateTime?
  totalPerson      Int

  // ROOM
  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id])

  // POOL
  poolSlots ReservationPoolSlot[]

  // STAFF USER
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  totalAmount Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addOns   ReservationAddOn[]
  payments Payment[]
}

model ReservationPoolSlot {
  id            String      @id @default(uuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  poolSlotId    String
  poolSlot      PoolSlot    @relation(fields: [poolSlotId], references: [id])
  poolDate      DateTime

  @@unique([poolSlotId, poolDate]) // prevent double booking per slot per date
}

//////////////////////
// ADD-ONS
//////////////////////

model AddOn {
  id        String   @id @default(uuid())
  name      String
  price     Decimal
  quantity  Int      @default(0) // how many are available
  unit      String? // e.g. "pcs", "sets"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservationAddOns ReservationAddOn[]
}

model ReservationAddOn {
  id            String      @id @default(uuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  addOnId       String
  addOn         AddOn       @relation(fields: [addOnId], references: [id])
  quantity      Int         @default(1)
  price         Decimal // snapshot of price at time of booking

  @@unique([reservationId, addOnId])
}

//////////////////////
// PAYMENT
//////////////////////

model Payment {
  id            String   @id @default(uuid())
  reservationId String
  amount        Decimal
  method        String
  paidAt        DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id])
}

//////////////////////
// INVENTORY
//////////////////////

model InventoryItem {
  id            String        @id @default(uuid())
  name          String
  description   String?
  type          InventoryType
  quantity      Int           @default(0)
  unit          String // e.g. "pcs", "liters", "kg"
  lowStockAlert Int // alert when quantity falls below this
  price         Decimal? // only relevant for SHOP items
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isActive      Boolean       @default(true)

  movements InventoryMovement[]
}

model InventoryMovement {
  id          String        @id @default(uuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  type        MovementType
  quantity    Int
  reason      String? // e.g. "restocked", "sold", "used for maintenance"
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
}

//////////////////////
// MAINTENANCE
//////////////////////

model MaintenanceLog {
  id          String          @id @default(uuid())
  type        MaintenanceType
  description String?
  performedBy String?
  createdAt   DateTime        @default(now())
}

model MaintenanceTask {
  id          String        @id @default(uuid())
  title       String
  description String?
  frequency   TaskFrequency
  status      TaskStatus    @default(PENDING)
  dueDate     DateTime
  completedAt DateTime?
  remarks     String? // optional, staff adds when completing
  photoUrl    String? // optional, proof photo

  // assigned to
  assignedToId String
  assignedTo   User   @relation("TaskAssignedTo", fields: [assignedToId], references: [id])

  // created by (admin only)
  createdById String
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// FEEDBACK
//////////////////////

model Feedback {
  id            String  @id @default(uuid())
  rating        Int // 1-5
  comment       String?
  isAnonymous   Boolean @default(false)
  customerName  String?
  customerEmail String?
  customerPhone String?

  createdAt DateTime @default(now())
}
